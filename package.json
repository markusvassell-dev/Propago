{
  "name": "propago",
  "version": "1.1.0",
  "private": true,
  "description": "Propago — marketing automation hub: Karbon-triggered content pipeline with human review gates, WordPress deploy, Meta Ads, ActiveCampaign and organic social publishing. Content generation via direct OpenAI (ChatGPT API).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "db:migrate": "node dist/scripts/migrate.js",
    "db:migrate:dev": "ts-node src/scripts/migrate.ts",
    "db:seed-demo": "node dist/scripts/seedDemo.js",
    "db:seed-demo:dev": "ts-node src/scripts/seedDemo.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  }
}
